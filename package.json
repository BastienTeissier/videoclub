{
  "name": "@repo/root",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "typecheck": "turbo run typecheck",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "db:up": "docker compose -f infra/docker/compose.yaml --env-file infra/docker/.env up -d",
    "db:down": "docker compose -f infra/docker/compose.yaml --env-file infra/docker/.env down",
    "db:generate": "pnpm --filter @repo/db exec drizzle-kit generate",
    "db:migrate": "pnpm --filter @repo/db exec drizzle-kit migrate",
    "db:push": "pnpm --filter @repo/db exec drizzle-kit push",
    "db:studio": "pnpm --filter @repo/db exec drizzle-kit studio",
    "depcruise": "depcruise apps packages --config .dependency-cruiser.cjs"
  },
  "devDependencies": {
    "dependency-cruiser": "^17.3.9",
    "turbo": "^2.8.20"
  },
  "packageManager": "pnpm@10.6.5"
}
